entrypoint = "main.py"
modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "glibcLocales", "libiconv", "libxcrypt", "openssl", "pkg-config", "rustc"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["sh", "-c", "streamlit run main.py --server.port $PORT --server.address 0.0.0.0 --server.headless true --server.fileWatcherType none"]
deploymentTarget = "cloudrun"

[workflows]
runButton = "Snowbird App (Diagnostic)"

[[workflows.workflow]]
name = "Run Streamlit App"
author = 45618204
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run main.py --server.port 5000 --server.address 0.0.0.0"

[[workflows.workflow]]
name = "Run Snowbird App"
author = 45618204
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run main.py --server.port 5000 --server.address 0.0.0.0 --browser.gatherUsageStats false --server.headless true --server.enableCORS false --server.enableWebsocketCompression false --server.maxUploadSize 200"

[[workflows.workflow]]
name = "Run Snowbird App (Stable)"
author = 45618204
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run main.py --server.port 5000 --server.address 0.0.0.0 --server.headless true --server.enableXsrfProtection false --server.enableCORS true --server.enableWebsocketCompression false --server.maxUploadSize 200 --browser.gatherUsageStats false --server.allowRunOnSave false"

[[workflows.workflow]]
name = "Snowbird App (Fixed)"
author = 45618204
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f streamlit || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run main.py --server.port 8501 --server.address 0.0.0.0 --server.headless true --server.enableXsrfProtection false --server.enableCORS false --server.enableWebsocketCompression false --server.maxUploadSize 200 --browser.gatherUsageStats false --server.allowRunOnSave false --server.fileWatcherType none"

[[workflows.workflow]]
name = "Snowbird App (Stable Fixed)"
author = 45618204
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f \"streamlit.*main.py\" || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 3"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run main.py --server.port 8501 --server.address 0.0.0.0 --server.headless true --server.enableCORS false --server.enableWebsocketCompression false --server.fileWatcherType none --browser.gatherUsageStats false"

[[workflows.workflow]]
name = "Snowbird App (Clean Start)"
author = 45618204
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f \"streamlit\" || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run main.py --server.port 8501 --server.address 0.0.0.0 --server.headless true --server.enableCORS false --server.enableWebsocketCompression false --server.fileWatcherType none --browser.gatherUsageStats false --logger.level error"

[[workflows.workflow]]
name = "Snowbird App (Stable)"
author = 45618204
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f \"streamlit\" || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 3"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run main.py --server.port 8501 --server.address 0.0.0.0 --server.headless true --server.enableCORS false --server.enableWebsocketCompression false --server.fileWatcherType none --browser.gatherUsageStats false --logger.level error --server.maxMessageSize 200 --server.enableStaticServing false"

[[workflows.workflow]]
name = "Snowbird App (PWA Optimized)"
author = 45618204
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f \"streamlit\" || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run main.py --server.port 8501 --server.address 0.0.0.0 --server.headless true --server.enableCORS false --server.enableWebsocketCompression false --server.fileWatcherType none --browser.gatherUsageStats false --logger.level error --server.maxMessageSize 200 --server.enableStaticServing true --server.baseUrlPath \"\""

[[workflows.workflow]]
name = "Snowbird App (Settings)"
author = 45618204
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f \"streamlit\" || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 3"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -c \"from utils.config import settings; import os; os.system(f'streamlit run main.py --server.port {settings.STREAMLIT_PORT} --server.address {settings.STREAMLIT_HOST} --server.headless true --server.enableCORS false --server.enableWebsocketCompression false --server.fileWatcherType none --browser.gatherUsageStats false --logger.level error --server.maxMessageSize 200 --server.enableStaticServing false')\""

[[workflows.workflow]]
name = "Snowbird App (Settings Fixed)"
author = 45618204
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f \"streamlit\" || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 3"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -c \""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "from utils.config import settings"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "import subprocess"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "import sys"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cmd = ["

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    sys.executable, '-m', 'streamlit', 'run', 'main.py',"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--server.port', str(settings.STREAMLIT_PORT),"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--server.address', settings.STREAMLIT_HOST,"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--server.headless', 'true',"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--server.enableCORS', 'false',"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--server.enableWebsocketCompression', 'false',"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--server.fileWatcherType', 'none',"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--browser.gatherUsageStats', 'false',"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--logger.level', 'error'"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "]"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "subprocess.run(cmd)"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "\""

