[[workflows.workflow.tasks]]
task = "shell.exec"
args = "import subprocess"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "import os"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Ensure logs directory exists"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "os.makedirs('logs', exist_ok=True)"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Simple streamlit command without complex imports"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cmd = ["

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    sys.executable, '-m', 'streamlit', 'run', 'main.py',"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--server.port', '8501',"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--server.address', '0.0.0.0',"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--server.headless', 'true',"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--server.enableCORS', 'false',"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--server.enableWebsocketCompression', 'false',"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    '--server.fileWatcherType', 'none',"

[[workflows.workflow.tasks]]
task = "shell.exec"
