args = "    '--logger.level', 'warning'"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "]"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "subprocess.run(cmd)"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "\""

