entrypoint = "main.py"
modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-25_05"

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["sh", "-c", "streamlit run main.py --server.port $PORT --server.address 0.0.0.0 --server.headless true --server.fileWatcherType none"]
deploymentTarget = "cloudrun"

[workflows]
runButton = "Run Snowbird App"

[[workflows.workflow]]
name = "Run Streamlit App"
author = 45618204
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run main.py --server.port 5000 --server.address 0.0.0.0"

[[workflows.workflow]]
name = "Run Snowbird App"
author = 45618204
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run main.py --server.port 5000 --server.address 0.0.0.0 --browser.gatherUsageStats false --theme.base light"

[[ports]]
localPort = 5000
externalPort = 80
