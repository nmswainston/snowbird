
[flake8]
max-line-length = 88
exclude = 
    .git,
    __pycache__,
    .pytest_cache,
    .github,
    logs,
    Phone App,
    tests/__pycache__
ignore = 
    E203,  # whitespace before ':'
    E501,  # line too long (handled by black)
    W503,  # line break before binary operator
    F401,  # imported but unused (common in __init__.py)
per-file-ignores =
    __init__.py:F401
    tests/*:F401,F811
max-complexity = 10
select = E,W,F,C
