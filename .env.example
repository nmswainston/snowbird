
# Snowbird Financial Assistant - Environment Variables
# Copy this file to .env and fill in your actual values

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
GMAIL_CREDENTIALS_FILE=path/to/gmail/credentials.json

# Email Settings (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
NOTIFICATION_EMAIL=your_notification_email@gmail.com

# Application Settings
ENVIRONMENT=development
DEBUG=true
TAX_THRESHOLD=183
MAX_SEARCH_RESULTS=50

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# Feature Flags
ENABLE_GMAIL_INTEGRATION=true
ENABLE_AI_FEATURES=true
ENABLE_NOTIFICATIONS=true
ENABLE_AUTO_LOGGING=false

# Security
SECRET_KEY=change-this-in-production

# Notification Settings
DAILY_REMINDER_TIME=09:00

# Cache Settings
CACHE_TTL=3600

# Error Monitoring & Logging
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=INFO
ENABLE_PERFORMANCE_MONITORING=true
ERROR_NOTIFICATION_EMAIL=admin@yourdomain.com

# Database (future use)
# DATABASE_URL=sqlite:///snowbird.db
# Firebase Configuration (required for user authentication)
FIREBASE_SERVICE_ACCOUNT={"type": "service_account", "project_id": "your-project-id"}
FIREBASE_CONFIG={"apiKey": "your-api-key", "authDomain": "your-project.firebaseapp.com", "projectId": "your-project-id"}
